rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // Hardened Schema Validations
    function isValidCatalogItem(data) {
      return data.id is string && data.id.size() <= 64 &&
             data.title is string && data.title.size() <= 200 &&
             data.type in ["Películas", "Series", "Documentales", "Anime"] &&
             // Poster/backdrop can be empty if not from TMDB but user usually wants them
             (data.poster is string) && data.poster.size() <= 500 &&
             (data.backdrop is string) && data.backdrop.size() <= 500 &&
             data.year is string && data.year.size() <= 10 &&
             data.status in ["En Vivo", "Próximamente", "Borrador"];
    }

    function isValidViewsData(data) {
      return data.keys().hasAll(['data']) && data.data is map;
    }

    // CATALOG COLLECTION
    match /catalog/{itemId} {
      allow get, list: if true;
      allow create, update: if isValidId(itemId) && isValidCatalogItem(incoming());
      allow delete: if true; 
    }

    // STATS COLLECTION
    match /stats/{itemId} {
      allow get, list: if true;
      allow write: if isValidId(itemId);
    }

    // USERS COLLECTION
    // Note: This is a custom auth system storing passwords in Firestore.
    // For production, use Firebase Authentication.
    match /users/{userId} {
      allow read: if true;
      allow create, update: if incoming().username is string && incoming().password is string;
      allow delete: if true;
    }
  }
}
